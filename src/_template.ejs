<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Актуальные новости</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: sans-serif;
            padding: 20px;
        }

        .rubric {
            margin-bottom: 32px;
        }

        .news__card {
            display: block;
            margin-bottom: 20px;
            border-bottom: 1px solid #ccc;
            padding-bottom: 12px;
            text-decoration: none;
            color: inherit;
        }

        .news__card img {
            max-width: 100%;
            height: auto;
            display: block;
            margin-bottom: 8px;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <% Object.entries(context).forEach(function([rubricTitle, newsItems]) { %>
        <div class="rubric">
            <h1><%= rubricTitle %></h1>
            <% newsItems.forEach(function(newsItem) { %>
            <div class="news__card">
                <% if (newsItem.enclosure) { %>
                <img src="<%- newsItem.enclosure %>" alt="<%- newsItem.title %>">
                <% } %>
                <h2><a href="<%- newsItem.link %>"><%- newsItem.title %></a></h2>
                <p><small><%= newsItem.author %> | <%= newsItem.pubDate %></small></p>
                <p><%- newsItem.description %></p>
            </div>
            <% }) %>
        </div>
        <% }) %>
    </div>
</body>

</html>