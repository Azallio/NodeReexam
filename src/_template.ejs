<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Актуальные новости</title>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Source Sans Pro', sans-serif;
        }

        .rubric-title {
            font-size: 1.5em;
            margin: 1em 0 0.5em;
        }

        .news__card {
            display: block;
            margin-bottom: 1.5em;
            text-decoration: none;
            color: inherit;
        }

        .news__card img {
            max-width: 100%;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <% Object.entries(context).forEach(function([rubricTitle, newsItems]) { %>
            <h1 class="rubric-title"><%- rubricTitle %></h1>
            <div class="news">
                <% newsItems.forEach(function(newsItem) { %>
                    <a href="<%- newsItem.link %>" class="news__card">
                        <% if (newsItem.enclosure) { %>
                            <img src="<%- newsItem.enclosure %>" alt="<%- newsItem.title %>">
                        <% } %>
                        <h2><%- newsItem.title %></h2>
                        <p><%- newsItem.description %></p>
                        <small><%- newsItem.author %> — <%- newsItem.pubDate %></small>
                    </a>
                <% }) %>
            </div>
        <% }) %>
    </div>
</body>

</html>